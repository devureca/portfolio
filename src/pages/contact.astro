---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contacto — devureca">
    <Navbar />
    <Footer />

    <main
        class="w-full max-w-md mx-auto border-x border-zinc-300/60 dark:border-zinc-900 pt-20 px-5 lg:px-6 min-h-screen flex flex-col opacity-0 animate-[fadeInUp_0.6s_ease-out_forwards]"
    >
        <div class="grow flex flex-col justify-end pb-12">
            <div class="flex flex-col gap-6 text-zinc-700 dark:text-zinc-300">
                <h1
                    class="text-sm font-bold text-zinc-900 dark:text-zinc-100 tracking-tight"
                >
                    Contacto
                </h1>

                <div
                    class="prose dark:prose-invert text-xs font-light tracking-wide leading-relaxed flex flex-col gap-4 antialiased"
                >
                    <p>
                        Si tienes un proyecto en mente puedes encontrarme en mis
                        canales principales:
                    </p>

                    <ul class="flex flex-col gap-2 mt-4 font-mono text-xs">
                        <li>
                            <span class="text-zinc-400 dark:text-zinc-500"
                                >Email:</span
                            >
                            <a
                                href="mailto:hola@devureca.com"
                                class="text-zinc-900 dark:text-zinc-100 hover:underline ml-1"
                                >hola@devureca.com</a
                            >
                        </li>
                        <li>
                            <span class="text-zinc-400 dark:text-zinc-500"
                                >GitHub:</span
                            >
                            <a
                                href="https://github.com/devureca"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-zinc-900 dark:text-zinc-100 hover:underline ml-1"
                                >github.com/devureca</a
                            >
                        </li>
                        <li>
                            <span class="text-zinc-400 dark:text-zinc-500"
                                >Twitter:</span
                            >
                            <a
                                href="https://x.com/devureca"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-zinc-900 dark:text-zinc-100 hover:underline ml-1"
                                >@devureca</a
                            >
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div
            class="lg:hidden w-full text-center py-8 border-t border-zinc-300/20 dark:border-zinc-900/50 static bottom-0"
        >
            <p class="text-xs text-zinc-500 dark:text-zinc-600">
                © 2026 devureca
            </p>
        </div>
    </main>
</Layout>
