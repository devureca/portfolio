---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
    const logs: CollectionEntry<"logs">[] = await getCollection("logs");
    return logs.map((log: CollectionEntry<"logs">) => ({
        params: { id: log.id },
        props: { log },
    }));
}

interface Props {
    log: CollectionEntry<"logs">;
}

const { log } = Astro.props;
const { Content } = await render(log);

const formatDate = (date: Date) => {
    return date.toLocaleDateString("es-ES", {
        year: "numeric",
        month: "long",
        day: "numeric",
        timeZone: "UTC",
    });
};
---

<Layout title={`${log.data.title} — devureca`}>
    <Navbar />
    <Footer />

    <main
        class="w-full max-w-md mx-auto border-x border-zinc-300/60 dark:border-zinc-900 pt-24 px-5 lg:px-6 min-h-screen flex flex-col opacity-0 animate-[fadeInUp_0.6s_ease-out_forwards]"
    >
        <div class="grow pb-16 text-zinc-700 dark:text-zinc-300">
            <div class="flex flex-col gap-2 mb-6">
                <span
                    class="text-[10px] font-mono text-zinc-400 dark:text-zinc-500 uppercase tracking-wider"
                >
                    {formatDate(log.data.date)}
                </span>
                <h1
                    class="text-sm font-bold text-zinc-900 dark:text-zinc-100 tracking-tight font-mono"
                >
                    {log.data.title}
                </h1>
            </div>

            <article
                class="prose dark:prose-invert text-xs font-light tracking-wide leading-relaxed flex flex-col gap-4 antialiased selection:bg-[#FE5126]/10"
            >
                <Content />
            </article>
        </div>

        <div
            class="lg:hidden w-full text-center py-8 border-t border-zinc-300/20 dark:border-zinc-900/50 static bottom-0"
        >
            <p class="text-xs text-zinc-500 dark:text-zinc-600">
                © 2026 devureca
            </p>
        </div>
    </main>
</Layout>
