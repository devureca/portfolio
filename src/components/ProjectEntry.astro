---
interface Props {
    id: string;
    title: string;
    tags: string[];
    url: string;
    imageUrl: string;
}

const { id, title, tags, url, imageUrl } = Astro.props;
---

<article class="flex flex-col gap-3 group">
    <div
        class="w-full overflow-hidden border border-zinc-300 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900 aspect-4/3 flex items-center justify-between"
    >
        <img src={imageUrl} alt={title} class="w-full h-full object-cover" />
    </div>

    <div class="flex flex-col gap-1.5">
        <a href={`/projects/${id}`} class="group cursor-pointer">
            <h3 class="text-sm font-medium text-zinc-900 dark:text-zinc-200">
                {title}
            </h3>
        </a>

        <div class="flex flex-wrap gap-1.5">
            {
                tags.map((tag) => (
                    <span class="text-[10px] px-2 py-0.5 bg-zinc-200/60 dark:bg-zinc-800/60 text-zinc-600 dark:text-zinc-400 font-mono">
                        #{tag}
                    </span>
                ))
            }
        </div>

        <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-zinc-400 dark:text-zinc-500 hover:text-[#FE5126] dark:hover:text-zinc-300 break-all transition-colors duration-200 underline underline-offset-4 decoration-zinc-300 dark:decoration-zinc-800"
        >
            {url}
        </a>
    </div>
</article>
