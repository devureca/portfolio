---
import ThemeToggle from "./ui/ThemeToggle.astro";

const links = [
    { label: "Inicio", href: "/" },
    { label: "Acerca", href: "/about" },
    { label: "Portfolio", href: "#portfolio" },
    { label: "Logs", href: "#blog" },
    { label: "Contacto", href: "/contact" },
];

const socials = [
    { label: "gh", href: "https://github.com/" },
    { label: "li", href: "https://linkedin.com/" },
    { label: "x", href: "https://x.com/" },
];
---

<aside
    class="hidden lg:flex fixed top-0 left-16 h-screen w-40 flex-col justify-between px-6 py-8 z-10"
>
    <div>
        <p
            class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 tracking-wide"
        >
            devureca
        </p>
        <p class="text-xs text-zinc-500 dark:text-zinc-600 mt-0.5 mb-6">
            ~/.developer
        </p>
        <hr class="border-zinc-300 dark:border-zinc-800 mb-6" />
        <nav>
            <ul class="flex flex-col gap-1">
                {
                    links.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                class="text-xs text-zinc-600 dark:text-zinc-400 hover:text-[#FE5126] dark:hover:text-zinc-100 transition-colors duration-200"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>
    <div class="flex gap-3">
        {
            socials.map((s) => (
                <a
                    href={s.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-zinc-500 dark:text-zinc-600 hover:text-[#FE5126] dark:hover:text-zinc-100 transition-colors duration-200"
                >
                    {s.label}
                </a>
            ))
        }
        <ThemeToggle />
    </div>
</aside>

<header
    class="lg:hidden fixed top-0 left-0 right-0 z-20 bg-[#f5f5f4] dark:bg-[#0a0a0a] border-b border-zinc-300/40 dark:border-zinc-900/50 transition-colors duration-200"
>
    <div class="flex items-center justify-between px-5 py-4">
        <div>
            <a
                href="/"
                class="block hover:opacity-80 transition-opacity"
                aria-label="Volver al inicio"
            >
                <p
                    class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 tracking-wide"
                >
                    devureca
                </p>
            </a>
        </div>
        <div class="flex items-center gap-4">
            {
                socials.map((s) => (
                    <a
                        href={s.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs text-zinc-500 dark:text-zinc-600 hover:text-[#FE5126] dark:hover:text-zinc-100 transition-colors duration-200"
                    >
                        {s.label}
                    </a>
                ))
            }
            <ThemeToggle />
            <button
                id="menu-toggle"
                class="flex flex-col gap-1.5 p-1 text-zinc-600 dark:text-zinc-400 hover:text-[#FE5126] dark:hover:text-zinc-100 transition-colors"
                aria-label="Abrir menú"
                aria-expanded="false"
            >
                <span
                    class="block w-5 h-px bg-current transition-all duration-300"
                    id="bar1"></span>
                <span
                    class="block w-5 h-px bg-current transition-all duration-300"
                    id="bar2"></span>
                <span
                    class="block w-3 h-px bg-current transition-all duration-300"
                    id="bar3"></span>
            </button>
        </div>
    </div>

    <div id="mobile-menu" class="hidden px-5 pb-5 flex-col gap-4">
        <nav>
            <ul class="flex flex-col gap-2 pt-2">
                {
                    links
                        .filter((link) => link.href !== "/") // Filtra y remueve el enlace a la raíz (Inicio)
                        .map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-[#FE5126] dark:hover:text-zinc-100 transition-colors duration-200 mobile-link"
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                }
            </ul>
        </nav>
    </div>
</header>

<script>
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const bar3 = document.getElementById("bar3");

    toggle?.addEventListener("click", () => {
        const isOpen = menu?.classList.contains("hidden");

        if (isOpen) {
            menu?.classList.remove("hidden");
            menu?.classList.add("flex");
            bar3?.classList.replace("w-3", "w-5");
            toggle.setAttribute("aria-expanded", "true");
        } else {
            menu?.classList.add("hidden");
            menu?.classList.remove("flex");
            bar3?.classList.replace("w-5", "w-3");
            toggle.setAttribute("aria-expanded", "false");
        }
    });

    document.querySelectorAll(".mobile-link").forEach((link) => {
        link.addEventListener("click", () => {
            menu?.classList.add("hidden");
            menu?.classList.remove("flex");
            bar3?.classList.replace("w-5", "w-3");
            toggle?.setAttribute("aria-expanded", "false");
        });
    });
</script>
